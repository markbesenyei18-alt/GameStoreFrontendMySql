@page "/Filmek"
@inject FilmekClient Client
@using System.Linq

@attribute [StreamRendering]

@rendermode InteractiveServer
@inject NavigationManager nav
<PageTitle>Filmek Catalog</PageTitle>

<div class="mt-2">
        <button class="btn btn-primary" @onclick='() => nav.NavigateTo("/editfilm")'>New Film</button>
</div>

@if(filmek is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table table-striped table-bordered table-hover mt-3">
        <thead class="table-dark">
            <th>Id</th>
            <th>Cim</th>    
            <th>Mufaj</th>
            <th>Hossz</th>
            <th>Nyelv</th>
            <th>MegjelenesiDatum</th>
            <th>imDbErtekeles</th>
            <th>SajatErtekeles</th>
            <th></th>
        </thead>
        <tbody>
            @foreach (var (film, index) in filmek.Select((FilmekDetails f, int i) => (f, i)))
            {
                <tr>
                    <td>@(index+1)</td>                    
                    <td>@film.Cim</td> 
                    <td>@film.MufajId</td>             
                    <td>@film.Hossz.ToString()</td>
                    <td>@film.Nyelv</td>
                    <td>@film.MegjelenesiDatum.ToString()</td>
                    <td>@film.ImDbErtekeles</td>
                    <td>@film.SajatErtekeles</td>
                    <td>
                        <div class="d-flex">
                            <a class="btn btn-primary me-2" role="button" href="@FilmUrl(film.Id)">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <!--<button class="btn btn-danger" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="@GetDeleteModalId(film)">
                                <i class="bi bi-x-lg"></i>
                            </button>-->
                        </div>
                        <DeleteFilm Film="@film" />
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private FilmekDetails[]? filmek;

    protected override async Task OnInitializedAsync()
    {
        filmek = await Client.GetFilmekAsync();
    }

    private static string FilmUrl(int id) => $"/editfilm/{id}";

    /*private string GetDeleteModalId(Film_castDetails film)
    {
        return $"#{DeleteSzinesz.GetModalId(szinesz)}";
    }*/
}