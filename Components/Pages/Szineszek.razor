@page "/szineszek"
@inject SzineszekClient Client

@attribute [StreamRendering]

@rendermode InteractiveServer
@inject NavigationManager nav
<PageTitle>Szineszek Catalog</PageTitle>

<div class="mt-2">
        <button class="btn btn-primary" @onclick='() => nav.NavigateTo("/editszinesz")'>New Szinesz</button>
</div>

@if(szineszek is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table table-striped table-bordered table-hover mt-3">
        <thead class="table-dark">
            <th>Id</th>
            <th>Name</th>           
            <th></th>
        </thead>
        <tbody>
            @foreach (var (szinesz, index) in szineszek.Select((s, i) => (s, i)))
            {
                <tr>
                    <td>@(index+1)</td>
                    <td>@szinesz.Name</td>              
                    <td>
                        <div class="d-flex">
                            <a class="btn btn-primary me-2" role="button" href="@SzineszUrl(szinesz.Id)">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <!--<button class="btn btn-danger" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="@GetDeleteModalId(szinesz)">
                                <i class="bi bi-x-lg"></i>
                            </button>-->
                        </div>
                        <!-- <DeleteSzinesz Szinesz="@szinesz" /> -->
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private SzineszekDetails[]? szineszek;

    protected override async Task OnInitializedAsync()
    {
        szineszek = await Client.GetSzineszekAsync();
    }

    private static string SzineszUrl(int id) => $"/editszinesz/{id}";

    /*private string GetDeleteModalId(SzineszekDetails szinesz)
    {
        return $"#{DeleteSzinesz.GetModalId(szinesz)}";
    }*/
}